# Application
APP_PORT=7621
SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-XX:+UseG1GC -XX:InitialRAMPercentage=10.0 -XX:MaxRAMPercentage=60.0 -XX:MaxGCPauseMillis=200 -XX:+ExitOnOutOfMemoryError
APP_TMPFS_SIZE=64m
APP_PIDS_LIMIT=256
APP_MEM_LIMIT=768m
APP_MEM_RESERVATION=512m
APP_CPUS_LIMIT=1.0

# PostgreSQL
POSTGRES_DB=narada
POSTGRES_USER=narada
POSTGRES_PASSWORD=narada_dev_password
POSTGRES_PORT=7622
POSTGRES_PIDS_LIMIT=256
POSTGRES_MEM_LIMIT=512m
POSTGRES_MEM_RESERVATION=256m
POSTGRES_CPUS_LIMIT=1.0
